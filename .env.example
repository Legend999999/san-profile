NEXT_PUBLIC_SITE_URL=https://san.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-server-only-service-role-key

# Optional simple admin login. Use server-side environment values only.
ADMIN_USERNAME=adminsan
ADMIN_PASSWORD=change-this-password

# Generic screenshot provider endpoint that returns a PNG image.
# Keep keys server-side only. Never prefix these with NEXT_PUBLIC_.
SCREENSHOT_API_ENDPOINT=https://api.example-screenshot-provider.com/capture
SCREENSHOT_API_KEY=your-screenshot-provider-key
